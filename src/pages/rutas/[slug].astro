---
import Base from '../../layouts/Base.astro';
import ListaPasos from '../../components/ListaPasos.svelte';
import { getCollection } from 'astro:content';
import { RUTAS } from '../../data/rutas';

export async function getStaticPaths() {
  return RUTAS.map((ruta) => ({ params: { slug: ruta.slug }, props: { ruta } }));
}

const { ruta } = Astro.props;

// Las rutas con guías propias generan sus pasos desde la colección.
const guias = (await getCollection('guias', (g) => g.data.ruta === ruta.slug)).sort(
  (a, b) => a.data.orden - b.data.orden
);

// Cada paso lleva una `key` estable para el progreso: id de guía o href del paso.
const pasos =
  guias.length > 0
    ? guias.map((g) => ({
        tipo: 'guia' as const,
        titulo: g.data.title,
        href: `/rutas/${ruta.slug}/${g.id}`,
        meta: g.data.duracion,
        key: g.id,
      }))
    : ruta.pasos.map((p) => ({ ...p, key: p.href }));

const tieneContrato =
  ruta.aprenderas?.length || ruta.requisitos?.length || ruta.noIncluye?.length;
---

<Base title={ruta.titulo} description={ruta.descripcion} activeHref="/rutas">
  <div class="container">
    <section class="section">
      <p class="eyebrow">guía · {ruta.nivel} · {ruta.duracion}</p>
      <h1>{ruta.titulo}</h1>
      <p class="lead" style="max-width: 42rem;">{ruta.descripcion}</p>
      {ruta.paraQuien && <p class="meta" style="max-width: 42rem;">Para ti si: {ruta.paraQuien}</p>}

      {
        tieneContrato && (
          <div class="grid-3" style="margin-top: 2.5rem;">
            {ruta.aprenderas?.length && (
              <div class="card">
                <h3>Qué te llevas</h3>
                <ul class="lista-check">
                  {ruta.aprenderas.map((x) => (
                    <li>{x}</li>
                  ))}
                </ul>
              </div>
            )}
            {ruta.requisitos?.length && (
              <div class="card">
                <h3>Requisitos</h3>
                <ul class="lista-check lista-check--neutro">
                  {ruta.requisitos.map((x) => (
                    <li>{x}</li>
                  ))}
                </ul>
              </div>
            )}
            {ruta.noIncluye?.length && (
              <div class="card">
                <h3>Qué NO cubre</h3>
                <ul class="lista-check lista-check--no">
                  {ruta.noIncluye.map((x) => (
                    <li>{x}</li>
                  ))}
                </ul>
              </div>
            )}
          </div>
        )
      }

      <h2 style="margin-top: 3rem;">El recorrido</h2>
      <ListaPasos client:load ruta={ruta.slug} pasos={pasos} />

      <p style="margin-top: 2rem;">
        <a href="/rutas">← Todas las rutas</a>
      </p>
    </section>
  </div>
</Base>
