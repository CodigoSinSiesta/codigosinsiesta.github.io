---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const ensayos = (await getCollection('ensayos')).sort(
  (a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf()
);

const fmtFecha = (d: Date) =>
  d.toLocaleDateString('es-ES', { year: 'numeric', month: 'short', day: '2-digit' });

// Build tag counts, sorted by frequency
const tagCounts = new Map<string, number>();
for (const post of ensayos) {
  for (const tag of post.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  }
}
const sortedTags = Array.from(tagCounts.entries()).sort((a, b) => b[1] - a[1]);
---

<Base
  title="Artículos"
  description="Artículos técnicos de Código Sin Siesta: agentic engineering, harness engineering, agentes de IA y disciplina de software."
  activeHref="/ensayos"
>
  <div class="container">
    <section class="section">
      <p class="eyebrow">artículos</p>
      <h1>Artículos</h1>
      <p class="lead" style="max-width: 40rem;">
        Claims fuertes con evidencia al lado. Lo que aprendemos construyendo en público, escrito
        para que te sirva.
      </p>

      <!-- Tag filter bar -->
      <nav class="tag-cloud" aria-label="Filtrar por tema" style="margin-top: 2rem;">
        <a href="/ensayos" class="tag tag--active">todos</a>
        {
          sortedTags.map(([tag, count]) => (
            <a href={`/ensayos/tags/${tag}`} class="tag">{tag}<sup>{count}</sup></a>
          ))
        }
      </nav>

      <ul class="item-list" style="margin-top: 2.5rem;">
        {
          ensayos.map((post) => (
            <li>
              <p class="meta">
                {fmtFecha(post.data.fecha)} · {post.data.autor}
              </p>
              <h3>
                <a href={`/ensayos/${post.id}`}>{post.data.title}</a>
              </h3>
              <p>{post.data.description}</p>
              <p style="margin-top: 0.6rem; margin-bottom: 0;">
                {post.data.tags.slice(0, 4).map((tag) => (
                  <a href={`/ensayos/tags/${tag}`} class="tag">{tag}</a>
                ))}
              </p>
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</Base>
