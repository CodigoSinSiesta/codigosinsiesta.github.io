---
import { NAV, SITE } from '../data/site';

interface Props {
  activeHref?: string;
}
const { activeHref = '' } = Astro.props;

const isActive = (href: string) =>
  href === '/' ? activeHref === '/' : activeHref.startsWith(href);
---

<header class="site-header" data-csi-header>
  <div class="site-header__bar">
    <a class="brand" href="/" aria-label={`${SITE.nombre} — inicio`}>
      <!-- búho line-art, usa currentColor para el glow -->
      <svg class="brand__owl" viewBox="25940 20865 18235 13449" aria-hidden="true"><g fill="currentColor" transform="scale(69.3555)"><path d="M589.101 360.074C591.869 358.292 597.719 355.519 600.847 353.924C602.794 356.48 604.808 359.714 606.597 362.44C623.252 389.004 626.849 420.901 604.912 446.158C585.302 468.737 547.778 472.61 525.096 452.012C520.101 460.517 516.039 468.896 510.723 477.568C506.619 469.032 502.192 460.655 497.452 452.455C490.683 458.77 480.102 463.442 471.02 464.843C438.832 469.809 408.761 447.734 404.085 415.423C400.449 390.299 408.751 373.454 422.938 353.781C427.504 356.758 429.417 357.64 434.396 359.821C432.652 361.878 431.008 364.018 429.469 366.233C384.113 431.377 464.177 484.652 500.054 430.435C503.067 434.628 508.314 444.435 511.362 449.491C513.805 445.157 519.531 434.661 522.508 431.188C531.663 441.817 541.7 450.955 555.987 452.456C582.667 455.26 605.292 435.608 607.367 409.154C608.946 389.019 601.068 374.903 589.101 360.074Z"/><path d="M611.748 311.086C615.282 311.435 620.461 311.318 623.994 310.931C622.865 322.387 621.431 328.761 613.782 337.655C599.064 353.343 573.268 354.631 553.684 362.806C527.511 373.731 522.7 387.22 512.449 411.324C508.387 402.997 504.443 394.844 499.983 386.966C481.597 354.493 440.861 361.866 414.338 342.076C403.944 334.321 401.197 324.115 399.935 311.401C402.592 311.456 404.973 311.373 407.615 311.273C409.374 311.15 409.957 311.135 411.709 311.244C413.195 313.068 413.414 319.757 416.295 324.664C425.011 339.507 449.563 342.493 464.784 347.084C485.788 353.418 501.09 362.707 511.855 382.067C525.713 356.031 549.949 349.191 576.3 342.19C584.408 339.754 592.432 337.458 599.49 332.61C607.901 326.833 610.086 320.575 611.748 311.086Z"/><path d="M500.362 323.713C522.82 321.922 549.098 325.617 569.321 335.574C564.502 338.856 560.246 340.693 555.534 344.383C544.754 339.687 535.807 337.91 524.125 336.591C503.495 335.586 487.693 336.076 468.244 344.284C464.403 341.022 458.855 338.295 454.356 335.796C466.119 327.801 486.414 324.975 500.362 323.713Z"/></g>
<g fill="none" stroke="currentColor" stroke-width="470" stroke-linejoin="round" stroke-linecap="round"><circle cx="32320" cy="28010" r="1950"/><circle cx="38908" cy="28010" r="1950"/><path d="M35610 30600 L34850 31600 L35610 32850 L36370 31600 Z"/></g>
<g fill="currentColor"><circle cx="32320" cy="28010" r="560"/><circle cx="38908" cy="28010" r="560"/></g></svg>
      <span class="brand__name">Código<b>SinSiesta</b></span>
    </a>

    <!-- nav: se renderiza UNA sola vez. En desktop es inline; en móvil colapsa
         en este mismo <details> (hamburguesa CSS-only, sin JS, sin isla). -->
    <details class="nav">
      <summary class="nav__toggle" aria-label="Abrir menú">
        <span class="nav__toggle-bars" aria-hidden="true"></span>
      </summary>
      <nav class="nav__list" aria-label="Navegación principal">
        {
          NAV.map((item) => (
            <a
              class:list={['nav__link', { 'nav__link--active': isActive(item.href) }]}
              href={item.href}
              aria-current={isActive(item.href) ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))
        }
        <a class="nav__cta" href="https://github.com/CodigoSinSiesta" target="_blank" rel="noopener">
          GitHub ↗
        </a>
      </nav>
    </details>
  </div>
</header>

<script>
  // sombra/opacidad al hacer scroll — progressive enhancement, no imprescindible
  const h = document.querySelector('[data-csi-header]');
  if (h) {
    const onScroll = () => h.classList.toggle('site-header--scrolled', window.scrollY > 8);
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
  }

  /* la barra translúcida cubre todo el ancho del viewport vía ::after */
  .site-header::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    background: rgba(15, 23, 42, 0.55);
    backdrop-filter: blur(14px) saturate(140%);
    border-bottom: 1px solid transparent;
    transition: background var(--transition-base), border-color var(--transition-base);
  }

  .site-header--scrolled::after {
    background: rgba(12, 18, 32, 0.88);
    border-bottom-color: var(--color-borde);
  }

  .site-header__bar {
    position: relative;
    max-width: 1100px;
    margin-inline: auto;
    padding: 0.85rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  /* ─── marca ─── */
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
  }
  .brand:hover { text-decoration: none; }

  .brand__owl {
    width: 30px;
    height: 30px;
    color: var(--color-cielo);
    filter: drop-shadow(0 0 6px rgba(96, 165, 250, 0.45));
    transition: transform var(--transition-base), color var(--transition-base);
  }
  .brand:hover .brand__owl {
    color: var(--color-cielo2);
    transform: rotate(-6deg) scale(1.06);
  }

  .brand__name {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.05rem;
    letter-spacing: -0.01em;
    color: var(--color-tinta);
  }
  .brand__name b {
    font-weight: 800;
    background: linear-gradient(90deg, var(--color-electrico), var(--color-cielo));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  /* ─── nav (una sola lista) ─── */
  .nav {
    position: relative;
  }
  .nav__toggle {
    display: none;
    list-style: none;
    cursor: pointer;
    width: 42px;
    height: 42px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-borde);
    align-items: center;
    justify-content: center;
  }
  .nav__toggle::-webkit-details-marker { display: none; }
  .nav__toggle-bars,
  .nav__toggle-bars::before,
  .nav__toggle-bars::after {
    content: '';
    display: block;
    width: 18px;
    height: 2px;
    background: var(--color-tinta);
    border-radius: 2px;
    transition: transform var(--transition-fast), opacity var(--transition-fast);
  }
  .nav__toggle-bars { position: relative; }
  .nav__toggle-bars::before { position: absolute; top: -6px; }
  .nav__toggle-bars::after { position: absolute; top: 6px; }

  .nav__list {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  .nav__link {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--color-tinta2);
    padding: 0.45rem 0.85rem;
    border-radius: var(--radius-sm);
    transition: color var(--transition-fast), background var(--transition-fast);
  }
  .nav__link:hover {
    text-decoration: none;
    color: var(--color-tinta);
    background: var(--color-accent-soft);
  }
  .nav__link--active {
    color: var(--color-cielo);
    background: var(--color-accent-soft);
  }

  .nav__cta {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    margin-left: 0.5rem;
    padding: 0.5rem 0.95rem;
    border-radius: var(--radius-sm);
    border: 1px solid var(--color-borde2);
    color: var(--color-tinta);
    transition: border-color var(--transition-fast), background var(--transition-fast),
      transform var(--transition-fast);
  }
  .nav__cta:hover {
    text-decoration: none;
    border-color: var(--color-cielo);
    background: var(--color-accent-soft);
    transform: translateY(-1px);
  }

  /* ─── responsive: < 880px → hamburguesa CSS-only ─── */
  @media (max-width: 879px) {
    .nav__toggle { display: inline-flex; }

    .nav__list {
      position: absolute;
      right: 0;
      top: calc(100% + 0.6rem);
      flex-direction: column;
      align-items: stretch;
      gap: 0.2rem;
      min-width: 220px;
      padding: 0.6rem;
      background: rgba(12, 18, 32, 0.97);
      border: 1px solid var(--color-borde);
      border-radius: var(--radius-md);
      box-shadow: 0 18px 50px rgba(8, 12, 24, 0.55);
      opacity: 0;
      transform: translateY(-6px);
      pointer-events: none;
      transition: opacity var(--transition-fast), transform var(--transition-fast);
    }

    /* sólo se muestra cuando el <details> está [open] */
    .nav[open] .nav__list {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }

    .nav[open] .nav__toggle-bars { background: transparent; }
    .nav[open] .nav__toggle-bars::before { transform: translateY(6px) rotate(45deg); }
    .nav[open] .nav__toggle-bars::after { transform: translateY(-6px) rotate(-45deg); }

    .nav__link { padding: 0.6rem 0.8rem; }
    .nav__cta { margin-left: 0; text-align: center; margin-top: 0.3rem; }
  }

  @media (prefers-reduced-motion: reduce) {
    .brand__owl, .nav__cta, .nav__list, .nav__toggle-bars,
    .nav__toggle-bars::before, .nav__toggle-bars::after { transition: none; }
  }
</style>
