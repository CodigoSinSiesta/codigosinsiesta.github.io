---
import Base from '../layouts/Base.astro';
import TerminalHero from '../components/TerminalHero.svelte';
import { getCollection } from 'astro:content';
import { RUTAS } from '../data/rutas';
import { TALLERES } from '../data/talleres';

const todosEnsayos = (await getCollection('ensayos')).sort(
  (a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf()
);
const ensayos = todosEnsayos.slice(0, 4);

const fmtFecha = (d: Date) =>
  d.toLocaleDateString('es-ES', { year: 'numeric', month: 'short', day: '2-digit' });

const proof = [
  { n: `${todosEnsayos.length}`, label: 'artículos publicados' },
  { n: `${RUTAS.length}`, label: 'rutas guiadas' },
  { n: `${TALLERES.length}`, label: 'talleres hands-on' },
];
---

<Base activeHref="/">
  <!-- ░░ hero full-bleed ░░ -->
  <section class="hero">
    <div class="hero__bg" aria-hidden="true">
      <div class="hero__grid"></div>
      <div class="hero__orb hero__orb--1"></div>
      <div class="hero__orb hero__orb--2"></div>
      <div class="hero__orb hero__orb--3"></div>
    </div>

    <div class="container hero__inner">
      <p class="hero__boot">
        <svg class="hero__owl" viewBox="25940 20865 18235 13449" aria-hidden="true"><g fill="currentColor" transform="scale(69.3555)"><path d="M589.101 360.074C591.869 358.292 597.719 355.519 600.847 353.924C602.794 356.48 604.808 359.714 606.597 362.44C623.252 389.004 626.849 420.901 604.912 446.158C585.302 468.737 547.778 472.61 525.096 452.012C520.101 460.517 516.039 468.896 510.723 477.568C506.619 469.032 502.192 460.655 497.452 452.455C490.683 458.77 480.102 463.442 471.02 464.843C438.832 469.809 408.761 447.734 404.085 415.423C400.449 390.299 408.751 373.454 422.938 353.781C427.504 356.758 429.417 357.64 434.396 359.821C432.652 361.878 431.008 364.018 429.469 366.233C384.113 431.377 464.177 484.652 500.054 430.435C503.067 434.628 508.314 444.435 511.362 449.491C513.805 445.157 519.531 434.661 522.508 431.188C531.663 441.817 541.7 450.955 555.987 452.456C582.667 455.26 605.292 435.608 607.367 409.154C608.946 389.019 601.068 374.903 589.101 360.074Z"/><path d="M611.748 311.086C615.282 311.435 620.461 311.318 623.994 310.931C622.865 322.387 621.431 328.761 613.782 337.655C599.064 353.343 573.268 354.631 553.684 362.806C527.511 373.731 522.7 387.22 512.449 411.324C508.387 402.997 504.443 394.844 499.983 386.966C481.597 354.493 440.861 361.866 414.338 342.076C403.944 334.321 401.197 324.115 399.935 311.401C402.592 311.456 404.973 311.373 407.615 311.273C409.374 311.15 409.957 311.135 411.709 311.244C413.195 313.068 413.414 319.757 416.295 324.664C425.011 339.507 449.563 342.493 464.784 347.084C485.788 353.418 501.09 362.707 511.855 382.067C525.713 356.031 549.949 349.191 576.3 342.19C584.408 339.754 592.432 337.458 599.49 332.61C607.901 326.833 610.086 320.575 611.748 311.086Z"/><path d="M500.362 323.713C522.82 321.922 549.098 325.617 569.321 335.574C564.502 338.856 560.246 340.693 555.534 344.383C544.754 339.687 535.807 337.91 524.125 336.591C503.495 335.586 487.693 336.076 468.244 344.284C464.403 341.022 458.855 338.295 454.356 335.796C466.119 327.801 486.414 324.975 500.362 323.713Z"/></g>
<g fill="none" stroke="currentColor" stroke-width="470" stroke-linejoin="round" stroke-linecap="round"><circle cx="32320" cy="28010" r="1950"/><circle cx="38908" cy="28010" r="1950"/><path d="M35610 30600 L34850 31600 L35610 32850 L36370 31600 Z"/></g>
<g fill="currentColor"><circle cx="32320" cy="28010" r="560"/><circle cx="38908" cy="28010" r="560"/></g></svg>
        <span class="hero__boot-text">
          dev@codigosinsiesta:~$ <span class="hero__boot-cmd">init --calidad</span><span class="hero__cursor" aria-hidden="true"></span>
        </span>
      </p>

      <h1 class="hero__title">
        Construye con IA<br />
        <span class="hl">sin perder el techo de calidad.</span>
      </h1>

      <p class="hero__lead">
        El vibe coding elevó el suelo. Nosotros entrenamos el techo.
        Rutas, ensayos y talleres para developers que quieren ingeniería de verdad
        en la era de los agentes — sin humo y sin atajos.
      </p>

      <div class="hero-ctas">
        <a class="btn btn--primary" href="/rutas">Ver las guías →</a>
        <a class="btn btn--ghost" href="/ensayos">Leer artículos</a>
      </div>

      <ul class="hero__proof">
        {
          proof.map((p) => (
            <li>
              <b>{p.n}</b>
              <span>{p.label}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <a class="hero__scroll" href="#contenido" aria-label="Bajar al contenido">
      <span></span>
    </a>
  </section>

  <!-- ░░ manifiesto / terminal ░░ -->
  <section class="manifiesto" id="contenido">
    <div class="container manifiesto__grid">
      <div>
        <p class="eyebrow">el manifiesto</p>
        <h2>No competimos con tu agente.<br /><span class="hl">Lo dirigimos.</span></h2>
        <p>
          Un agente acelera la escritura de código. La calidad, la arquitectura y el criterio
          siguen siendo tuyos. Aquí aprendes a pilotarlo: <em>harness engineering</em>,
          patrones de orquestación y disciplina de ingeniería aplicada.
        </p>
        <p style="margin-top: 1.25rem;">
          <a href="/ensayos/del-vibe-coding-al-agentic-engineering">Del vibe coding al agentic engineering →</a>
        </p>
      </div>
      <TerminalHero client:visible />
    </div>
  </section>

  <!-- ░░ contenido ░░ -->
  <div class="container">
    <!-- rutas -->
    <section class="section">
      <p class="eyebrow">guías</p>
      <h2>Guías de aprendizaje</h2>
      <p>Itinerarios curados, de cero a producción. Cada paso es un artículo, un deck o un taller.</p>
      <div class="grid-2" style="margin-top: 2rem;">
        {
          RUTAS.map((ruta) => (
            <a class="card card--ruta" href={`/rutas/${ruta.slug}`}>
              <span class={`badge ${ruta.nivel === 'inicial' ? 'badge--ok' : ''}`}>
                {ruta.nivel}
              </span>
              <h3 style="margin-top: 0.9rem;">{ruta.titulo}</h3>
              <p>{ruta.claim}</p>
              <p class="meta" style="margin-top: 0.8rem;">{ruta.duracion}</p>
            </a>
          ))
        }
      </div>
    </section>

    <!-- ensayos -->
    <section class="section" style="padding-top: 0;">
      <p class="eyebrow">artículos</p>
      <h2>Últimos artículos</h2>
      <ul class="item-list">
        {
          ensayos.map((post) => (
            <li>
              <p class="meta">{fmtFecha(post.data.fecha)}</p>
              <h3>
                <a href={`/ensayos/${post.id}`}>{post.data.title}</a>
              </h3>
              <p>{post.data.description}</p>
            </li>
          ))
        }
      </ul>
      <p style="margin-top: 1.5rem;">
        <a href="/ensayos">Todos los artículos →</a>
      </p>
    </section>

    <!-- talleres -->
    <section class="section" style="padding-top: 0;">
      <p class="eyebrow">hands-on</p>
      <h2>Talleres</h2>
      <div class="grid-2" style="margin-top: 2rem;">
        {
          TALLERES.map((taller) => (
            <a class="card" href="/talleres">
              <h3>{taller.titulo}</h3>
              <p>{taller.descripcion}</p>
            </a>
          ))
        }
      </div>
    </section>
  </div>
</Base>
