---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const ensayos = await getCollection('ensayos');
  return ensayos.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const fmtFecha = (d: Date) =>
  d.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title={post.data.title} description={post.data.description} activeHref="/ensayos">
  <div class="container">
    <article class="section">
      <header style="max-width: 760px;">
        <p class="eyebrow">ensayo · {fmtFecha(post.data.fecha)}</p>
        <h1 style="font-size: clamp(1.9rem, 4.5vw, 2.8rem);">{post.data.title}</h1>
        <p class="meta">{post.data.autor}</p>
        <p style="margin-top: 0.75rem;">
          {post.data.tags.map((tag) => <span class="tag">{tag}</span>)}
        </p>
      </header>
      <div class="prose">
        <Content />
      </div>
      <footer style="margin-top: 3.5rem; border-top: 1px solid var(--color-borde); padding-top: 1.5rem;">
        <a href="/ensayos">← Todos los ensayos</a>
      </footer>
    </article>
  </div>
</Base>
